<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cz.webmaster.mapper.MobileBlackMapper">

    <resultMap id="BaseResultMap" type="com.cz.webmaster.entity.MobileBlack">
        <id column="id" jdbcType="BIGINT" property="id"/>
        <result column="blackNumber" jdbcType="VARCHAR" property="blackNumber"/>
        <result column="blackType" jdbcType="INTEGER" property="blackType"/>
        <result column="clientId" jdbcType="INTEGER" property="clientId"/>
        <result column="created" jdbcType="TIMESTAMP" property="created"/>
        <result column="createId" jdbcType="BIGINT" property="createId"/>
        <result column="updated" jdbcType="TIMESTAMP" property="updated"/>
        <result column="updateId" jdbcType="BIGINT" property="updateId"/>
        <result column="isDelete" jdbcType="TINYINT" property="isDelete"/>
        <result column="extend1" jdbcType="VARCHAR" property="extend1"/>
        <result column="extend2" jdbcType="VARCHAR" property="extend2"/>
        <result column="extend3" jdbcType="VARCHAR" property="extend3"/>
        <result column="extend4" jdbcType="VARCHAR" property="extend4"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,
        black_number as blackNumber,
        black_type as blackType,
        client_id as clientId,
        created,
        create_id as createId,
        updated,
        update_id as updateId,
        is_delete as isDelete,
        extend1,
        extend2,
        extend3,
        extend4
    </sql>

    <sql id="Search_Condition">
        <if test="keyword != null and keyword != ''">
            and (
                black_number like concat('%', #{keyword}, '%')
                or cast(client_id as char) like concat('%', #{keyword}, '%')
            )
        </if>
    </sql>

    <select id="findListByPage" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from mobile_black
        where is_delete = 0
        <include refid="Search_Condition"/>
        order by id desc
        limit #{offset}, #{limit}
    </select>

    <select id="countByKeyword" resultType="java.lang.Long">
        select count(1)
        from mobile_black
        where is_delete = 0
        <include refid="Search_Condition"/>
    </select>

    <select id="findById" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from mobile_black
        where id = #{id}
        and is_delete = 0
    </select>

    <select id="findByIds" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from mobile_black
        where is_delete = 0
        and id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="findAllActive" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from mobile_black
        where is_delete = 0
        order by id asc
    </select>

    <insert id="insertSelective" parameterType="com.cz.webmaster.entity.MobileBlack">
        insert into mobile_black
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="blackNumber != null">black_number,</if>
            <if test="blackType != null">black_type,</if>
            <if test="clientId != null">client_id,</if>
            <if test="created != null">created,</if>
            <if test="createId != null">create_id,</if>
            <if test="updated != null">updated,</if>
            <if test="updateId != null">update_id,</if>
            <if test="isDelete != null">is_delete,</if>
            <if test="extend1 != null">extend1,</if>
            <if test="extend2 != null">extend2,</if>
            <if test="extend3 != null">extend3,</if>
            <if test="extend4 != null">extend4,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="blackNumber != null">#{blackNumber},</if>
            <if test="blackType != null">#{blackType},</if>
            <if test="clientId != null">#{clientId},</if>
            <if test="created != null">#{created},</if>
            <if test="createId != null">#{createId},</if>
            <if test="updated != null">#{updated},</if>
            <if test="updateId != null">#{updateId},</if>
            <if test="isDelete != null">#{isDelete},</if>
            <if test="extend1 != null">#{extend1},</if>
            <if test="extend2 != null">#{extend2},</if>
            <if test="extend3 != null">#{extend3},</if>
            <if test="extend4 != null">#{extend4},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.cz.webmaster.entity.MobileBlack">
        update mobile_black
        <set>
            <if test="blackNumber != null">black_number = #{blackNumber},</if>
            <if test="blackType != null">black_type = #{blackType},</if>
            <if test="clientId != null">client_id = #{clientId},</if>
            <if test="updated != null">updated = #{updated},</if>
            <if test="updateId != null">update_id = #{updateId},</if>
            <if test="extend1 != null">extend1 = #{extend1},</if>
            <if test="extend2 != null">extend2 = #{extend2},</if>
            <if test="extend3 != null">extend3 = #{extend3},</if>
            <if test="extend4 != null">extend4 = #{extend4},</if>
        </set>
        where id = #{id}
        and is_delete = 0
    </update>

    <update id="deleteBatch">
        update mobile_black
        set is_delete = 1,
            updated = #{updated},
            update_id = #{updateId}
        where is_delete = 0
        and id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
